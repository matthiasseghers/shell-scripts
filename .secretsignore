# .secretsignore
# Patterns to ignore in secret scanning
# 
# Format:
#   file/path:line_number    - Ignore specific line in specific file
#   file/path                - Ignore entire file
#   # comment                - Comments start with #
#
# Examples:
#   scripts/backup/README.md:40    - Ignore line 40
#   docs/example.md                - Ignore entire file

